# === LLM Provider ===
# Choose one: openai | anthropic | ollama
LLM_PROVIDER=openai

# === OpenAI ===
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: custom base URL (for Azure OpenAI or proxies)
# OPENAI_BASE_URL=https://your-proxy.com/v1

# === OpenAI API Mode ===
# completions = /v1/chat/completions (default, widely compatible)
# responses = /v1/responses (OpenAI's newer API with extended features)
# OPENAI_API_MODE=completions

# === Extra Options ===
# Pass additional provider-specific options as JSON.
# These are spread directly into the SDK call, so you can use any
# option your provider supports without waiting for explicit Vitamem support.
# Examples:
#   For OpenAI: {"temperature": 0.7, "max_tokens": 1024, "reasoning": {"effort": "medium"}}
#   For DashScope: {"enable_search": true, "result_format": "message"}
# OPENAI_EXTRA_CHAT_OPTIONS={}
# OPENAI_EXTRA_EMBEDDING_OPTIONS={}

# === Anthropic (requires separate OpenAI key for embeddings) ===
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_CHAT_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_EMBEDDING_API_KEY=sk-...   # OpenAI key for embeddings
# ANTHROPIC_EMBEDDING_MODEL=text-embedding-3-small

# === DashScope (Alibaba Cloud - OpenAI compatible) ===
# Uses the OpenAI adapter with DashScope's compatible-mode endpoint.
# Supports both chat (Qwen models) and embeddings (text-embedding-v4).
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-dashscope-key
# OPENAI_CHAT_MODEL=qwen3.5-flash
# OPENAI_EMBEDDING_MODEL=text-embedding-v4
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_API_MODE=completions
#
# NOTE: DashScope requires enable_thinking=false for non-streaming calls.
# Vitamem uses non-streaming requests, so do NOT set enable_thinking: true.
# If you want thinking/reasoning, use a streaming-capable wrapper instead.
# OPENAI_EXTRA_CHAT_OPTIONS={}

# === Ollama (local, no API keys needed) ===
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_CHAT_MODEL=llama3.2
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# === Thread Lifecycle ===
# Choose a preset: daily-checkin | weekly-therapy | on-demand | long-term
PRESET=on-demand
# Or set custom timeouts (override preset):
# COOLING_TIMEOUT_MS=1800000
# DORMANT_TIMEOUT_MS=900000
# CLOSED_TIMEOUT_MS=2592000000

# === Retrieval Controls ===
AUTO_RETRIEVE=true
MIN_SCORE=0.3
RECENCY_WEIGHT=0.2
DIVERSITY_WEIGHT=0.1

# === Memory Intelligence ===
# Deduplication threshold (default: 0.92) — similarity above this = exact duplicate, skipped
# DEDUPLICATION_THRESHOLD=0.92
# Supersede threshold (default: 0.75) — similarity between this and dedup threshold = update existing memory
# SUPERSEDE_THRESHOLD=0.75
# Auto-pin critical health memories (allergy, blood type, contraindications, etc.)
AUTO_PIN=true

# === Demo Settings ===
DEMO_USER_ID=demo-user
PORT=3100
