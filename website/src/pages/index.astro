---
// Landing page - rendered as raw HTML to preserve inline CSS/JS
const html = `<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vitamem — Lifecycle-Aware Memory for AI</title>
    <meta
      name="description"
      content="Open-source TypeScript library that gives AI long-term memory. Models conversations as sessions with a lifecycle — extracting what matters when sessions rest, recalling it when users return."
    />
    <meta
      property="og:title"
      content="Vitamem — Lifecycle-Aware Memory for AI"
    />
    <meta
      property="og:description"
      content="Lifecycle-aware memory for AI. Extract once when sessions rest, recall always when users return — automatically."
    />
    <meta property="og:image" content="/brand/social-preview.png" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="/brand/social-preview.png" />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --teal: #0f766e;
        --teal-mid: #0d9488;
        --teal-lt: #14b8a6;
        --amber: #f59e0b;
        --rose: #f43f5e;
        --slate-dk: #0f172a;
        --slate: #1e293b;
        --mid: #334155;
        --silver: #94a3b8;
        --mist: #e2e8f0;
        --snow: #f8fafc;
        --border: rgba(255, 255, 255, 0.08);
        --teal-glow: rgba(15, 118, 110, 0.15);
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
        background: var(--slate-dk);
        color: var(--snow);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      /* ── Nav ── */
      nav {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(15, 23, 42, 0.92);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }
      .nav-inner {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 24px;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .nav-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
      }
      .nav-wordmark {
        font-size: 18px;
        font-weight: 700;
        color: var(--snow);
        letter-spacing: -0.3px;
      }
      .nav-wordmark span {
        color: var(--teal-lt);
      }
      .nav-links {
        display: flex;
        gap: 8px;
        list-style: none;
        align-items: center;
      }
      .nav-links a {
        font-size: 14px;
        color: var(--silver);
        text-decoration: none;
        padding: 6px 12px;
        border-radius: 6px;
        transition:
          color 0.15s,
          background 0.15s;
      }
      .nav-links a:hover {
        color: var(--snow);
        background: rgba(255, 255, 255, 0.06);
      }
      .nav-links .btn-nav {
        color: var(--teal-lt);
        border: 1px solid rgba(20, 184, 166, 0.3);
        background: rgba(20, 184, 166, 0.08);
      }
      .nav-links .btn-nav:hover {
        background: rgba(20, 184, 166, 0.15);
      }

      /* ── Container ── */
      .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 24px;
      }

      /* ── Hero ── */
      #hero {
        padding: 96px 0 48px;
        text-align: center;
      }

      .hero-label {
        display: inline-block;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: var(--teal-lt);
        background: var(--teal-glow);
        border: 1px solid rgba(20, 184, 166, 0.2);
        padding: 4px 12px;
        border-radius: 20px;
        margin-bottom: 24px;
      }

      .hero-logo {
        display: flex;
        justify-content: center;
        margin-bottom: 28px;
      }
      .hero-logo img {
        width: min(96px, 28vw);
        height: auto;
      }

      h1 {
        font-size: clamp(30px, 5.5vw, 50px);
        font-weight: 700;
        letter-spacing: -1.5px;
        line-height: 1.1;
        color: var(--snow);
        margin-bottom: 18px;
      }
      h1 em {
        font-style: normal;
        color: var(--teal-lt);
      }

      .hero-sub {
        font-size: 19px;
        color: var(--silver);
        max-width: 520px;
        margin: 0 auto 36px;
        line-height: 1.6;
      }

      .hero-clarifier {
        font-size: 15px;
        color: var(--silver);
        margin-top: 12px;
        max-width: 560px;
        margin-left: auto;
        margin-right: auto;
        text-align: center;
        line-height: 1.6;
      }

      .hero-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 32px;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 22px;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        text-decoration: none;
        transition:
          opacity 0.15s,
          transform 0.1s;
        cursor: pointer;
      }
      .btn:hover {
        opacity: 0.88;
        transform: translateY(-1px);
      }
      .btn-primary {
        background: var(--teal);
        color: #fff;
        border: 1.5px solid var(--teal);
      }
      .btn-secondary {
        background: transparent;
        color: var(--mist);
        border: 1.5px solid var(--mid);
      }

      .install-banner {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 11px 20px;
        background: var(--slate);
        border: 1px solid var(--border);
        border-radius: 10px;
        font-family: "SF Mono", "Fira Code", monospace;
        font-size: 14px;
        color: var(--mist);
        cursor: pointer;
        transition: border-color 0.2s;
      }
      .install-banner:hover {
        border-color: var(--teal);
      }
      .install-banner .prompt {
        color: var(--silver);
        user-select: none;
      }
      .install-banner .copy-hint {
        font-family: -apple-system, sans-serif;
        font-size: 11px;
        color: var(--mid);
        margin-left: 8px;
      }

      /* ── Sections ── */
      section {
        padding: 72px 0;
      }
      section + section {
        border-top: 1px solid var(--border);
      }
      .section-label {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--teal-lt);
        margin-bottom: 10px;
      }
      .section-title {
        font-size: clamp(22px, 3.5vw, 32px);
        font-weight: 700;
        letter-spacing: -0.8px;
        color: var(--snow);
        margin-bottom: 12px;
      }
      .section-desc {
        font-size: 16px;
        color: var(--silver);
        max-width: 540px;
        line-height: 1.7;
      }
      .section-header {
        margin-bottom: 40px;
      }

      /* ── Reveal ── */
      .reveal {
        opacity: 0;
        transform: translateY(20px);
        transition:
          opacity 0.55s ease,
          transform 0.55s ease;
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* ── Lifecycle ── */
      .lc-track {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0;
        margin-top: 36px;
        flex-wrap: wrap;
      }
      .lc-node {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 18px 20px;
        border-radius: 12px;
        cursor: pointer;
        border: 2px solid transparent;
        transition: all 0.25s ease;
        min-width: 130px;
        text-align: center;
      }
      .lc-node:hover,
      .lc-node.lc-active {
        transform: translateY(-3px);
      }
      .lc-dot {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        transition: transform 0.25s;
      }
      .lc-node:hover .lc-dot,
      .lc-node.lc-active .lc-dot {
        transform: scale(1.12);
      }
      .lc-name {
        font-size: 14px;
        font-weight: 600;
        color: var(--snow);
        margin-bottom: 2px;
      }
      .lc-hint {
        font-size: 11px;
        color: var(--silver);
      }

      .lc-node[data-state="active"] .lc-dot {
        background: var(--teal);
      }
      .lc-node[data-state="cooling"] .lc-dot {
        background: #7c3aed;
      }
      .lc-node[data-state="dormant"] .lc-dot {
        background: var(--amber);
      }
      .lc-node[data-state="closed"] .lc-dot {
        background: var(--mid);
      }

      .lc-node[data-state="active"].lc-active {
        border-color: var(--teal);
        background: var(--teal-glow);
      }
      .lc-node[data-state="cooling"].lc-active {
        border-color: #7c3aed;
        background: rgba(124, 58, 237, 0.1);
      }
      .lc-node[data-state="dormant"].lc-active {
        border-color: var(--amber);
        background: rgba(245, 158, 11, 0.1);
      }
      .lc-node[data-state="closed"].lc-active {
        border-color: var(--mid);
        background: rgba(51, 65, 85, 0.4);
      }

      .lc-arrow {
        font-size: 18px;
        color: var(--mid);
        padding: 0 4px;
      }

      .lc-detail {
        margin-top: 20px;
        padding: 22px;
        background: var(--slate);
        border: 1px solid var(--border);
        border-radius: 12px;
      }
      .lc-detail-title {
        font-size: 15px;
        font-weight: 600;
        color: var(--snow);
        margin-bottom: 6px;
      }
      .lc-detail-body {
        font-size: 14px;
        color: var(--silver);
        line-height: 1.7;
      }
      .lc-detail-body strong {
        color: var(--snow);
      }

      /* ── How It Works grid ── */
      .hiw-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        margin-top: 36px;
      }
      .hiw-step {
        background: var(--slate);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 24px;
        text-align: center;
        transition: border-color 0.2s, transform 0.2s;
      }
      .hiw-step:hover {
        border-color: rgba(20, 184, 166, 0.3);
        transform: translateY(-2px);
      }
      .hiw-num {
        width: 36px;
        height: 36px;
        background: var(--teal);
        color: #fff;
        font-size: 16px;
        font-weight: 700;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 14px;
      }
      .hiw-label {
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--teal-lt);
        margin-bottom: 8px;
      }
      .hiw-desc {
        font-size: 13px;
        color: var(--silver);
        line-height: 1.6;
      }
      .hiw-desc code {
        font-size: 11px;
        background: var(--mid);
        padding: 1px 5px;
        border-radius: 3px;
      }

      /* ── Claims grid ── */
      .claims-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 14px;
        margin-top: 36px;
      }
      .claim-card {
        background: var(--slate);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 22px;
        transition:
          border-color 0.2s,
          transform 0.2s;
      }
      .claim-card:hover {
        border-color: rgba(20, 184, 166, 0.3);
        transform: translateY(-2px);
      }
      .claim-num {
        font-size: 26px;
        font-weight: 700;
        letter-spacing: -1px;
        margin-bottom: 6px;
        line-height: 1;
      }
      .claim-num.teal {
        color: var(--teal-lt);
      }
      .claim-num.amber {
        color: var(--amber);
      }
      .claim-num.purple {
        color: #a78bfa;
      }
      .claim-num.rose {
        color: var(--rose);
      }
      .claim-title {
        font-size: 13px;
        font-weight: 600;
        color: var(--snow);
        margin-bottom: 4px;
      }
      .claim-desc {
        font-size: 12px;
        color: var(--silver);
        line-height: 1.6;
      }

      /* ── Embedding math callout ── */
      .math-callout {
        margin-top: 36px;
        padding: 24px;
        background: var(--slate);
        border: 1px solid rgba(20, 184, 166, 0.25);
        border-radius: 12px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
      }
      .math-col .math-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--silver);
        margin-bottom: 10px;
      }
      .math-col .math-value {
        font-size: 28px;
        font-weight: 700;
        letter-spacing: -1px;
        line-height: 1;
        margin-bottom: 6px;
      }
      .math-col.naive .math-value {
        color: var(--rose);
      }
      .math-col.vita .math-value {
        color: var(--teal-lt);
      }
      .math-col .math-desc {
        font-size: 13px;
        color: var(--silver);
        line-height: 1.5;
      }
      .math-footnote {
        grid-column: 1 / -1;
        font-size: 12px;
        color: var(--mid);
        border-top: 1px solid var(--border);
        padding-top: 12px;
        margin-top: 4px;
      }

      /* ── Cost comparison ── */
      .cost-comparison {
        grid-column: 1 / -1;
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding-top: 14px;
        border-top: 1px solid var(--border);
      }
      .cost-row {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
      }
      .cost-label {
        font-weight: 600;
        color: var(--mist);
        min-width: 140px;
      }
      .cost-value {
        color: var(--silver);
      }
      .cost-value.rose { color: var(--rose); }
      .cost-value.teal { color: var(--teal-lt); }

      /* ── Use cases ── */
      .use-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 14px;
        margin-top: 36px;
      }
      .use-card {
        background: var(--slate);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 22px;
        transition: border-color 0.2s;
      }
      .use-card:hover {
        border-color: rgba(20, 184, 166, 0.3);
      }
      .use-icon {
        font-size: 24px;
        margin-bottom: 12px;
      }
      .use-title {
        font-size: 15px;
        font-weight: 600;
        color: var(--snow);
        margin-bottom: 6px;
      }
      .use-desc {
        font-size: 13px;
        color: var(--silver);
        line-height: 1.6;
      }

      /* ── Documentation links ── */
      .docs-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
        gap: 14px;
        margin-top: 36px;
      }
      .docs-card {
        background: var(--slate);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 18px;
      }
      .docs-card-title {
        font-size: 13px;
        font-weight: 700;
        color: var(--mist);
        margin-bottom: 10px;
        letter-spacing: 0.3px;
      }
      .docs-links {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .docs-link {
        font-size: 13px;
        color: var(--silver);
        text-decoration: none;
        transition: color 0.15s;
      }
      .docs-link:hover {
        color: var(--teal-lt);
      }

      /* ── Code block ── */
      .code-wrap {
        background: var(--slate);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-top: 36px;
      }
      .code-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 16px;
        border-bottom: 1px solid var(--border);
      }
      .code-lang {
        font-size: 11px;
        font-weight: 600;
        color: var(--silver);
        letter-spacing: 0.5px;
      }
      .code-dots {
        display: flex;
        gap: 6px;
      }
      .code-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
      }
      pre {
        padding: 22px;
        overflow-x: auto;
        font-family: "SF Mono", "Fira Code", "Cascadia Code", monospace;
        font-size: 13px;
        line-height: 1.8;
        color: var(--snow);
        tab-size: 2;
      }
      .kw {
        color: #93c5fd;
      }
      .fn {
        color: #86efac;
      }
      .str {
        color: #fde68a;
      }
      .cm {
        color: #475569;
      }
      .cn {
        color: #c4b5fd;
      }
      .op {
        color: #94a3b8;
      }
      .hl {
        color: var(--teal-lt);
      }

      /* ── FAQ callout ── */
      .faq-callout {
        margin-top: 20px;
        padding: 16px 20px;
        background: var(--slate);
        border: 1px solid rgba(20, 184, 166, 0.2);
        border-radius: 10px;
        font-size: 13px;
        color: var(--silver);
        line-height: 1.6;
      }
      .faq-callout strong {
        color: var(--mist);
      }

      /* ── Disclaimer ── */
      .disclaimer {
        margin-top: 56px;
        padding: 20px 24px;
        background: rgba(244, 63, 94, 0.06);
        border: 1px solid rgba(244, 63, 94, 0.2);
        border-radius: 10px;
        font-size: 13px;
        color: var(--silver);
        line-height: 1.6;
      }
      .disclaimer strong {
        color: var(--mist);
      }

      /* ── Footer ── */
      footer {
        border-top: 1px solid var(--border);
        padding: 36px 0;
      }
      .footer-inner {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
      }
      .footer-name {
        font-size: 15px;
        font-weight: 700;
        color: var(--snow);
      }
      .footer-name span {
        color: var(--teal-lt);
      }
      .footer-meta {
        font-size: 12px;
        color: var(--mid);
        margin-top: 2px;
      }
      .footer-links {
        display: flex;
        gap: 20px;
      }
      .footer-links a {
        font-size: 13px;
        color: var(--mid);
        text-decoration: none;
        transition: color 0.15s;
      }
      .footer-links a:hover {
        color: var(--snow);
      }

      /* ── Responsive ── */
      @media (max-width: 640px) {
        section {
          padding: 48px 0;
        }
        #hero {
          padding: 60px 0 32px;
        }
        .lc-track {
          flex-direction: column;
          gap: 4px;
        }
        .lc-arrow {
          transform: rotate(90deg);
        }
        .claims-grid,
        .use-grid {
          grid-template-columns: 1fr 1fr;
        }
        .math-callout {
          grid-template-columns: 1fr;
        }
        .nav-links li:not(:last-child) {
          display: none;
        }
      }
      @media (max-width: 768px) {
        .hiw-grid {
          grid-template-columns: 1fr 1fr;
        }
      }
    </style>
  </head>
  <body>
    <nav>
      <div class="nav-inner">
        <a class="nav-logo" href="#hero">
          <img
            src="/brand/logo-concept-a.svg"
            alt="Vitamem"
            height="32"
            style="height: 32px; width: auto"
          />
          <span class="nav-wordmark">Vita<span>mem</span></span>
        </a>
        <ul class="nav-links">
          <li><a href="#lifecycle">Lifecycle</a></li>
          <li><a href="#why">Why Vitamem</a></li>
          <li><a href="/introduction/">Docs</a></li>
          <li><a href="#quick-start">Quick Start</a></li>
          <li><a href="/demo">Demo</a></li>
          <li>
            <a
              href="https://github.com/yuw321/Vitamem"
              target="_blank"
              rel="noopener"
              >GitHub</a
            >
          </li>
          <li><a href="#documentation" class="btn-nav">Docs →</a></li>
        </ul>
      </div>
    </nav>

    <!-- Hero -->
    <section id="hero">
      <div class="container">
        <div class="hero-label">
          Open Source · TypeScript · Zero Dependencies
        </div>
        <div class="hero-logo">
          <img src="/brand/logo-concept-a.svg" alt="Vitamem" />
        </div>
        <h1>
          Lifecycle-aware memory for AI.<br /><em>Extract once, recall always.</em>
        </h1>
        <p class="hero-sub">
          Vitamem models conversations as sessions with a lifecycle. When a session rests, it extracts the facts that matter, deduplicates them, and makes them available for every future conversation — automatically.
        </p>
        <p class="hero-clarifier">
          Five lines of code. Zero memory infrastructure to build. Works with any AI that talks to users across sessions.
        </p>
        <div class="hero-actions">
          <a href="/demo" class="btn btn-primary">
            <svg
              width="15"
              height="15"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              viewBox="0 0 24 24"
            >
              <polygon points="5 3 19 12 5 21 5 3" />
            </svg>
            See the Demo
          </a>
          <a href="#documentation" class="btn btn-secondary">Read the Docs</a>
          <a href="https://github.com/yuw321/Vitamem" class="btn btn-secondary">
