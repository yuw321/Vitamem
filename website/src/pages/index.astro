    <script>
      var stateInfo = {
        active: {
          title: "Active — session is live",
          body: "The user is actively checking in. Messages are stored in full fidelity. No embeddings are computed yet — doing so mid-conversation would waste API calls on incomplete context. The thread stays active as long as messages keep arriving, and automatically reactivates from cooling when a new message arrives.",
        },
        cooling: {
          title: "Cooling — between sessions",
          body: "The conversation has gone quiet. A configurable timer starts (default: 6 hours). If the user sends a new message, the thread <strong>automatically reactivates to Active</strong> — no manual intervention needed. This models the natural gap between sessions without losing context.",
        },
        dormant: {
          title: "Dormant — memories extracted and saved",
          body: "The key transition. Vitamem calls your LLM to extract facts from all conversation messages, embeds each fact (typically 5–10 API calls for a full session), deduplicates against existing memories using cosine similarity, and saves only genuinely new facts. This is the <strong>only time embeddings are computed</strong> for this thread.",
        },
        closed: {
          title: "Closed — archived permanently",
          body: 'The thread is done — either the user is done or the engagement has ended. The extracted memories remain in the store and are searchable indefinitely. No further processing happens on this thread. Invalid transitions from closed throw <code style="font-size:12px;background:#334155;padding:1px 4px;border-radius:3px;">InvalidTransitionError</code>.',
        },
      };

      function selectState(el) {
        document.querySelectorAll(".lc-node").forEach(function (n) {
          n.classList.remove("lc-active");
        });
        el.classList.add("lc-active");
        var s = stateInfo[el.dataset.state];
        document.getElementById("lc-title").textContent = s.title;
        document.getElementById("lc-body").innerHTML = s.body;
      }

      function copyInstall(el) {
        navigator.clipboard.writeText("npm install vitamem").then(function () {
          var hint = el.querySelector(".copy-hint");
          hint.textContent = "copied!";
          hint.style.color = "var(--teal-lt)";
          setTimeout(function () {
            hint.textContent = "click to copy";
            hint.style.color = "";
          }, 1800);
        });
      }

      // Scroll reveal
      var io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) e.target.classList.add("visible");
          });
        },
        { threshold: 0.1 },
      );
      document.querySelectorAll(".reveal").forEach(function (el) {
        io.observe(el);
      });

      // Auto-cycle lifecycle
      var states = ["active", "cooling", "dormant", "closed"];
      var idx = 0;
      var cycle = setInterval(function () {
        idx = (idx + 1) % states.length;
        selectState(
          document.querySelector('.lc-node[data-state="' + states[idx] + '"]'),
        );
      }, 3500);
      document
        .getElementById("lc-track")
        .addEventListener("click", function () {
          clearInterval(cycle);
        });
    </script>
  </body>
</html>
`;
