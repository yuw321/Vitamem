---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Open-source TypeScript library for AI health companions.', ogImage = '/brand/social-preview.png' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href="/favicon.svg" />
    <style is:inline>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --teal: #0f766e; --teal-mid: #0d9488; --teal-lt: #14b8a6;
        --amber: #f59e0b; --rose: #f43f5e; --green: #22c55e;
        --slate-dk: #0f172a; --slate: #1e293b; --mid: #334155;
        --silver: #94a3b8; --mist: #e2e8f0; --snow: #f8fafc;
        --border: rgba(255, 255, 255, 0.08);
        --teal-glow: rgba(15, 118, 110, 0.15);
      }
      html { scroll-behavior: smooth; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
        background: var(--slate-dk); color: var(--snow); line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      nav { position: sticky; top: 0; z-index: 100; background: rgba(15,23,42,0.92); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); }
      .nav-inner { max-width: 1100px; margin: 0 auto; padding: 0 24px; height: 56px; display: flex; align-items: center; justify-content: space-between; }
      .nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
      .nav-wordmark { font-size: 18px; font-weight: 700; color: var(--snow); letter-spacing: -0.3px; }
      .nav-wordmark span { color: var(--teal-lt); }
      .nav-links { display: flex; gap: 8px; list-style: none; align-items: center; }
      .nav-links a { font-size: 14px; color: var(--silver); text-decoration: none; padding: 6px 12px; border-radius: 6px; transition: color 0.15s, background 0.15s; }
      .nav-links a:hover { color: var(--snow); background: rgba(255,255,255,0.06); }
      footer { border-top: 1px solid var(--border); padding: 36px 0; }
      .footer-inner { max-width: 1100px; margin: 0 auto; padding: 0 24px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
      .footer-name { font-size: 15px; font-weight: 700; color: var(--snow); }
      .footer-name span { color: var(--teal-lt); }
      .footer-meta { font-size: 12px; color: var(--mid); margin-top: 2px; }
      .footer-links { display: flex; gap: 20px; }
      .footer-links a { font-size: 13px; color: var(--mid); text-decoration: none; transition: color 0.15s; }
      .footer-links a:hover { color: var(--snow); }
    </style>
  </head>
  <body>
    <nav>
      <div class="nav-inner">
        <a class="nav-logo" href="/">
          <img src="/brand/logo-concept-a.svg" alt="Vitamem" height="32" style="height: 32px; width: auto" />
          <span class="nav-wordmark">Vita<span>mem</span></span>
        </a>
        <ul class="nav-links">
          <li><a href="/">Home</a></li>
          <li><a href="/introduction/">Docs</a></li>
          <li><a href="/demo">Demo</a></li>
          <li><a href="https://github.com/yuw321/Vitamem" target="_blank" rel="noopener">GitHub</a></li>
        </ul>
      </div>
    </nav>

    <slot />

    <footer>
      <div class="footer-inner">
        <div>
          <div class="footer-name">Vita<span>mem</span></div>
          <div class="footer-meta">MIT License &middot; Open Source</div>
        </div>
        <div class="footer-links">
          <a href="https://github.com/yuw321/Vitamem" target="_blank" rel="noopener">GitHub</a>
          <a href="https://www.npmjs.com/package/vitamem" target="_blank" rel="noopener">npm</a>
          <a href="/introduction/">Docs</a>
          <a href="/demo">Demo</a>
          <a href="/legal/disclaimer/">Disclaimer</a>
        </div>
      </div>
    </footer>
  </body>
</html>
